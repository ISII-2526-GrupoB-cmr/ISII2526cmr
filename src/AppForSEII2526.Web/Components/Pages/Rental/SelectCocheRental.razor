@page "/rental/SelectCocheRental"


@using Microsoft.AspNetCore.Authorization
@using AppForSEII2526.Web.API
@inject AppForSEII2526APIClient apiclient
@inject ILogger<SelectCocheRental> logger
@inject RentalStateContainer rentalState
@inject NavigationManager navigation


@attribute [Authorize]

<h3>Select Cars For Rental</h3>
<div class="container-fluid">
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @errors</p>
    </div>
    <div class="row">
        <div class="col-8">
            <!-- FILTROS -->
            <div class="row">
                <div class="col">
                    <div class="input-group mb-3">
                        <span class="input-group-text">Max Price</span>
                        <input type="number" step="5" @bind="rentingPrice" class="form-control" placeholder="Price">
                    </div>
                </div>
                <!-- Select de Modelos -->
                <div class="col">
                    <div class="input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">Model</span>
                        <select class="form-select" aria-label="Default select" @bind="carModelSelected" id="selectModel">
                            <option value="All" selected>All</option>
                            @foreach (string modelName in modelsNames)
                            {
                                <option value="@modelName" id="modelNameSelected_@modelName">@modelName</option>
                            }
                        </select>
                    </div>
                </div>
                




                <div class="col">
                    <button type="button" class="btn btn-primary" @onclick=@SearchCars id="searchCars">Search cars</button>
                </div>

            </div>
            <div class="row">
                @if (cars == null)
                {
                    <p>Loading cars....</p>
                }
                else
                {
                    <div class="mh-100 table-responsive">
                        <table class="table table-condensed table-hover" id="TableOfCars">
                            <thead>
                                <tr>
                                    <th>Model</th>
                                    <th>Fuel Type</th>
                                    <th>Manufacturer</th>
                                    <th>Price for renting</th>
                                    <th>Color</th>
                                  

                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var car in cars)
                                {
                                    <tr id="CarData_@car.Model">
                                        <td>@car.Model</td>
                                        <td>@car.FuelType</td>
                                        <td>@car.Manufacturer</td>
                                        <td>@car.RentingPrice</td>
                                        <td>@car.Color</td>

                                        <td>
                                            <button class="btn btn-outline-secondary" id="carToPurchase_@car.Model" @onclick="@(() => AddCar(car))">Add</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                }
            </div>
        </div>
           
        </div>
        <div class="col-2" hidden="@hideRentingCart">
            <div class="row">
                <h3>Shopping Cart</h3>
            </div>
            @foreach (RentalItemDTO item in rental.RentalItems) {
                <div class="row">
                    <button type="button" class="btn btn-light" id="removecar_@item.Modelo" @onclick="@(() => RemoveRentalItem(item))">x @item.Modelo - @item.RentingPrice€</button>
                </div>
            }
            <div class="row">
                <button type="button" class="btn btn-primary" id="rentalcarButton" @onclick=@RentMovies>Rent movies</button>
            </div>
        </div>
        
 </div>



@code {
    private string carModelSelected;
    private ICollection<string>? modelsNames = new List<string>();
    private bool hideRentingCart { get { return rental.RentalItems.Count == 0; } }
    private ICollection<CocheParaAlquilarDTO> cars;
    private bool hideErrors { get { return errors.Length == 0; } }
    private string errors = "";
    private string carModelo { get; set; }
    private float rentingPrice { get; set; }
    private DateTime _from;
    private DateTime From {
        get { return _from; }
        set {
            if (_from != value) {
                //the rentingcart is cleared to ensure that only movies available for the selected period are selected
                _from = value;
                rental.StartDate = DateTime.SpecifyKind(_from, DateTimeKind.Utc);
                rentalState.ClearRentingCart();

            }
        }
    }

    private DateTime _to;
    private DateTime To {
        get { return _to; }
        set {
            if (_to != value) {
                //the rentingcart is cleared to ensure that only movies available for the selected period are selected
                _to = value;
                rental.StartDate = DateTime.SpecifyKind(_to, DateTimeKind.Utc);
                rentalState.ClearRentingCart();

            }
        }
    }
    private RentalForCreateDTO rental => rentalState.Rental;

    private bool hiddenRentingCart = true;

    private void AddCar(CocheParaAlquilarDTO movie) {
        rentalState.AddMovieToRental(movie);
    }

    private void RemoveRentalItem(RentalItemDTO item) {
        rentalState.RemoveRentalItemToRent(item);
        if (rental.RentalItems.Count == 0) hiddenRentingCart = true;
    }

    public async void SearchCars()
    {
        // Si el usuario escribe texto en el input, ese es el filtro
        // Si no escribe nada, usamos el modelo del dropdown (si no es "All")
        string? modeloFiltro =
            !string.IsNullOrWhiteSpace(carModelo)
                ? carModelo
                : (carModelSelected == "All" ? null : carModelSelected);

        // Validaciones fechas
        if (rental.StartDate > rental.EndDate)
        {
            errors = "Your rental must end after than it starts";
            return;
        }

        if (rental.StartDate < DateTime.Today || rental.EndDate < DateTime.Today)
        {
            errors = "Your rental period must be later";
            return;
        }

        try
        {
            cars = await apiclient.GetCocheParaAlquilarAsync(rentingPrice, modeloFiltro);
            errors = "";
        }
        catch (ApiException ex)
        {
            logger.LogError($"{DateTime.Now} Error: {ex}");
            errors = "Error while connecting to the system";
        }

        StateHasChanged();
    
    }

    protected override async Task OnInitializedAsync() {

        try {
            modelsNames = await apiclient.GetModelsAsync(null);
        }
        catch (ApiException ex) {
            if (modelsNames == null) modelsNames = new List<string>() { "All", };
            logger.LogError("Error! There was an error while connecting to the GetGenresAsync service");
        }

        //the type of RentalDateFrom is DateTimeOffset, it is required a conversion
        //https://learn.microsoft.com/es-es/dotnet/standard/datetime/converting-between-datetime-and-offset
        _from = (_from == new DateTime(1, 1, 1)) ?
            DateTime.SpecifyKind(DateTime.Today.AddDays(1), DateTimeKind.Utc)
            : _from;
        rental.StartDate = _from;

        //the type of RentalDateFrom is DateTimeOffset, it is required a conversion
        //https://learn.microsoft.com/es-es/dotnet/standard/datetime/converting-between-datetime-and-offset
        _to = (_to == new DateTime(1, 1, 1)) ?
            DateTime.SpecifyKind(DateTime.Today.AddDays(2), DateTimeKind.Utc)
            : _to;
        rental.EndDate = _to;


       // return base.OnInitializedAsync();
    }

    private void RentMovies() {
        navigation.NavigateTo("/rental/CreateCocheRental");
    }

}

