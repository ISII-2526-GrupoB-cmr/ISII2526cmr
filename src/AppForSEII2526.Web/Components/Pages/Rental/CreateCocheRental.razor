@page "/rental/CreateCocheRental"


@using AppForSEII2526.Web.API
@using AppForSEII2526.Web.Components.Shared
@using Microsoft.AspNetCore.Authorization
@using System.Text.Json
@using Microsoft.AspNetCore.WebUtilities
@using System.Collections

@inject AppForSEII2526APIClient apiclient
@inject ILogger<CreateCocheRental> logger
@inject RentalStateContainer rentalState
@inject NavigationManager navigation


@attribute [Authorize]

<h3>CreateCocheRental</h3>

@* rental is the object that will be edited thanks to the form *@
<EditForm Model="rental" onsubmit="HandleSubmit">
    <div class="row">
        <DataAnnotationsValidator />
        <ValidationSummary class="row alert alert-danger" />
    </div>
    <div class="row alert alert-danger" role="alert" hidden="@hideErrors">
        <p id="ErrorsShown">Errors: @messageError</p>
    </div>
    <div class="row alert alert-danger" role="alert" hidden="@hideDateErrors">
        <p id="DateErrorsShown">@dateError</p>
    </div>

    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="rental.Name" class="form-control" id="Name" />
                <label for="Name">Name </label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="rental.Surname" class="form-control" id="Surname" />
                <label for="Surname">Surname </label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputText @bind-Value="rental.Address" class="form-control" id="Address" />
                <label for="Address"> Address</label>
            </div>
        </div>
    </div>
    <div class="row g-2">
        <div class="col-md">
            <div class="form-floating">
                @*a dropdown for selecting the payment method*@
                <InputSelect class="form-select" @bind-Value="@rental.PaymentMethod" id="PaymentMethod">
                    <option value="@PaymentMethodTypes.Paypal" default> Paypal</option>
                    <option value="@PaymentMethodTypes.Visa"> Visa</option>
                    <option value="@PaymentMethodTypes.GooglePay"> GooglePay</option>
                </InputSelect>
                <label for="PaymentMethod">Payment Method</label>
            </div>
        </div>
        <div class="col-md">
            <div class="form-floating">
                @*this button will be used to ask the user if he want to proceed to rent the movies*@
                <button class="btn btn-primary" type="submit" id="rentalcarButton">
                    Rent your cars
                </button>
            </div>
        </div>
    </div>
    <div class="row g-3">
        <div class="col-md">
            <div class="form-floating mb-3">
                <InputDate @bind-Value="rental.StartDate" class="form-control" id="StartDate" />
                <label for="StartDate">Date From</label>
            </div>
        </div>

        <div class="col-md">
            <div class="form-floating mb-3">
                <InputDate @bind-Value="rental.EndDate" class="form-control" id="EndDate" />
                <label for="EndDate">Date To</label>
            </div>
        </div>
    </div>
    <p>
        <b>Total price:</b> @TotalCost €
        <button class="btn btn-outline-primary" type="button" @onclick="ModifyRentalItems" id="Modifycars">
            Modify cars
        </button>
    </p>
    <div class="mh-100 table-responsive">
        <table class="table table-condensed table-hover" id="TableOfRentalItems">
            <thead>
                <tr>
                    <th>Modelo</th>
                    <th>Price for Renting</th>
                    <th>Manufacturer</th>
                    <th>Quantity</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in rental.RentalItems)
                {
                    <tr id="MovieData_@item.Modelo">
                        <td>@item.Modelo</td>
                        <td>@item.RentingPrice</td>
                        <td>@item.Manufacturer</td>
                        <td><InputNumber @bind-Value="item.Quantity" class="form-control" id="@($"quantity_{item.CarId}")" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</EditForm>

@*a modal popup dialog for checking if user wants to proceed to rent*@
@if (DialogIsOpen)
{
    <Dialog Caption="Rental cars"
            Message="Do you want to proceed to rent the selected cars?"
            OnClose="@OnDialogClose"
            Type=Dialog.Category.SaveNot>
    </Dialog>
}


@code {
    private string messageError = "";
    private bool hideErrors { get { return messageError.Length == 0; } }
    private string dateError = "";
    private bool hideDateErrors => string.IsNullOrWhiteSpace(dateError);

    private bool DialogIsOpen;

    private void HandleSubmit(EditContext editContext)
    {
        messageError = "";
        dateError = "";

        // Ejecuta DataAnnotations si las tienes (Required, etc.)
        editContext.Validate();
        if (string.IsNullOrWhiteSpace(rental.Name))
            messageError += "Name is required. ";

        if (string.IsNullOrWhiteSpace(rental.Surname))
            messageError += "Surname is required. ";

        if (string.IsNullOrWhiteSpace(rental.Address))
            messageError += "Address is required. ";

        // Tus validaciones custom
        if (rental.StartDate <= DateTime.Today)
            dateError = "Start date must be after today.";

        if (rental.EndDate <= rental.StartDate)
            dateError = "End date must be after start date.";

        if (!string.IsNullOrWhiteSpace(messageError) || !string.IsNullOrWhiteSpace(dateError))
        {
            DialogIsOpen = false;
            StateHasChanged();
            return;
        }

        DialogIsOpen = true;
        StateHasChanged();
    }

    private decimal TotalCost
    {
        get
        {
            var start = new DateTime(rental.StartDate.Year, rental.StartDate.Month, rental.StartDate.Day);
            var end = new DateTime(rental.EndDate.Year, rental.EndDate.Month, rental.EndDate.Day);

            int days = (end - start).Days;
            double price = rental.RentalItems.Sum(ri => ri.RentingPrice * days);
            return Convert.ToDecimal(price);
        }
    }
    private void ModifyRentalItems()
    {
        navigation.NavigateTo("/rental/SelectCocheRental");
    }

    private RentalForCreateDTO rental => rentalState.Rental;

    private void OpenDialog()
    {

        DialogIsOpen = true;
    }

    private async Task OnDialogClose(bool isOk)
    {

        DialogIsOpen = false;
        if (isOk)
        {
            // Process the data introduced by the user if they are valid
            if (rental.RentalItems.Count > 0)
            {
                try
                {
                    var rented = await apiclient.CreateRentalAsync(rental);
                    rentalState.RentalProcessed();
                    // Navigate to the details page for the created rental
                    navigation.NavigateTo($"/rental/detailcocherental?RentalID={rented.Id}");
                }
                catch (ApiException<ValidationProblemDetails> apiexceptionvalidation)
                {

                    if (apiexceptionvalidation.Result.Errors.Values != null)
                    {
                        messageError = "";
                        foreach (var errors in apiexceptionvalidation.Result.Errors.Values)
                            //https://learn.microsoft.com/en-us/dotnet/api/system.string.join?view=net-7.0
                            messageError = string.Join("(*) ", messageError, string.Join(" (*) ", errors));
                    }
                }
                catch (ApiException apiexception)
                {
                    // NSwag can throw ApiException even on success (2xx) if it can't deserialize the response.
                    logger.LogError(apiexception, "CreateRental failed. Status={Status}. Response={Response}", apiexception.StatusCode, apiexception.Response);

                    // If the API returned 201 Created, we treat it as success and try to extract the rental id from the raw JSON.
                    if ((int)apiexception.StatusCode == 201)
                    {
                        // 1) Try JSON body first (some setups return it correctly).
                        if (!string.IsNullOrWhiteSpace(apiexception.Response))
                        {
                            try
                            {
                                using var doc = JsonDocument.Parse(apiexception.Response);
                                if (doc.RootElement.TryGetProperty("id", out var idProp) && idProp.TryGetInt32(out var createdIdFromBody))
                                {
                                    rentalState.RentalProcessed();
                                    navigation.NavigateTo($"/rental/detailcocherental?RentalID={createdIdFromBody}");
                                    return;
                                }
                            }
                            catch (Exception parseEx)
                            {
                                logger.LogError(parseEx, "CreateRental returned 201 but response JSON couldn't be parsed.");
                            }
                        }

                        // 2) If body is empty, try the Location header from CreatedAtAction (usually contains ?id=123).
                        var location = TryGetHeaderValue(apiexception, "Location");
                        if (!string.IsNullOrWhiteSpace(location))
                        {
                            try
                            {
                                // Handle relative locations like "/api/Rentals/GetRental?id=123"
                                var loc = location.StartsWith("http", StringComparison.OrdinalIgnoreCase)
                                    ? new Uri(location, UriKind.Absolute)
                                    : new Uri("http://local" + location.TrimStart(), UriKind.Absolute);

                                var query = QueryHelpers.ParseQuery(loc.Query);
                                if (query.TryGetValue("id", out var idValues) && int.TryParse(idValues.FirstOrDefault(), out var createdIdFromLocation))
                                {
                                    rentalState.RentalProcessed();
                                    navigation.NavigateTo($"/rental/detailcocherental?RentalID={createdIdFromLocation}");
                                    return;
                                }

                                // Fallback: parse last segment as id (e.g., ".../123")
                                var lastSeg = loc.Segments.LastOrDefault()?.Trim('/', ' ');
                                if (!string.IsNullOrWhiteSpace(lastSeg) && int.TryParse(lastSeg, out var createdIdFromPath))
                                {
                                    rentalState.RentalProcessed();
                                    navigation.NavigateTo($"/rental/detailcocherental?RentalID={createdIdFromPath}");
                                    return;
                                }
                            }
                            catch (Exception locEx)
                            {
                                logger.LogError(locEx, "CreateRental returned 201 but Location header couldn't be parsed. Location={Location}", location);
                            }
                        }
                    }

                    // Otherwise show a helpful error. (We keep it short to avoid dumping huge HTML.)
                    var responseSnippet = string.IsNullOrWhiteSpace(apiexception.Response)
                        ? "(empty response)"
                        : (apiexception.Response.Length > 300 ? apiexception.Response[..300] + "..." : apiexception.Response);
                    messageError = $"Error while processing your request, please try again later! (HTTP {(int)apiexception.StatusCode}) {responseSnippet}";

                }

            }
        }
    }
    protected override async Task OnInitializedAsync()
    {

        if (authenticationState is not null)
        {
            var authState = await authenticationState;
            var user = authState?.User;


            rental.Name = rental.Name == null ? "" : rental.Name;
            rental.Surname = rental.Surname == null ? "" : rental.Surname;
            rental.Address = rental.Address == null ? "" : rental.Address;
            if (rental.StartDate == default)
                rental.StartDate = DateTime.Today.AddDays(1);

            if (rental.EndDate == default)
                rental.EndDate = DateTime.Today.AddDays(2);

        }
    }


    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState { get; set; }

    private static string? TryGetHeaderValue(ApiException ex, string headerName)
    {
        try
        {
            // ApiException type is generated; use reflection to read potential header dictionaries.
            var t = ex.GetType();
            var prop = t.GetProperty("Headers") ?? t.GetProperty("ResponseHeaders");
            var headersObj = prop?.GetValue(ex);
            if (headersObj is null) return null;

            // Common shape: IDictionary<string, IEnumerable<string>>
            if (headersObj is IDictionary dict)
            {
                foreach (DictionaryEntry entry in dict)
                {
                    if (entry.Key is string key && key.Equals(headerName, StringComparison.OrdinalIgnoreCase))
                    {
                        if (entry.Value is IEnumerable<string> strEnum) return strEnum.FirstOrDefault();
                        return entry.Value?.ToString();
                    }
                }
            }
        }
        catch
        {
            // ignore - best effort
        }
        return null;
    }
}